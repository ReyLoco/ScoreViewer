{
  "name": "scoreviewer",
  "version": "0.1.0",
  "author": "Luis Massó",
  "description": "Visual web to browse and view music scores and song sheets",
  "keywords": [
    "music",
    "scores",
    "sheet music",
    "songs",
    "viewer"
  ],
  "private": true,
  "dependencies": {
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "emailjs-com": "^3.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-pdf": "^10.4.1",
    "react-scripts": "^5.0.1",
    "sass": "^1.80.3",
    "web-vitals": "^4.2.4"
  },
  "scripts": {
    "prestart": "node scripts/generateSongs.js",
    "start": "react-scripts start",
    "prebuild": "node scripts/generateSongs.js",
    "postinstall": "node scripts/copyPdfWorker.js",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
